# Only change the IP if you're using a server with multiple network interfaces, otherwise change the port only.
endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"

# Hide built-in loading-game busy spinner for connecting clients.
set sv_showBusySpinnerOnLoadingScreen 0
setr sv_showBusySpinnerOnLoadingScreen 0

# Force public joins on startup unless you intentionally toggle maintenance later.
setr sv_maintenance false

# pma-voice: make voice routing explicit instead of relying on late runtime defaults.
setr voice_useNativeAudio true
setr voice_use2dAudio false
setr voice_useSendingRangeOnly false
setr voice_externalDisallowJoin 0
setr voice_enableCalls 1
setr voice_enableSubmix 0
setr voice_defaultCallVolume 80
setr voice_debugMode 4
setr voice_defaultVoiceMode 3
setr voice_enableUi 0
setr voice_enableProximityCycle 0

# These resources will start by default.
ensure chat
ensure oxmysql
ensure polyzone
ensure bob74_ipl-2.1.2
ensure phmc
ensure pma-voice

ensure lsrp_core
ensure lsrp_hud
ensure lsrp_dev
ensure lsrp_ems
ensure lsrp_economy
ensure lsrp_jobs
ensure lsrp_jobcenter
ensure lsrp_police
ensure lsrp_taxi
ensure lsrp_towing
ensure lsrp_fuel
ensure lsrp_hacking
ensure lsrp_nui_template
ensure lsrp_inventory
ensure lsrp_framework
ensure lsrp_hunger
ensure lsrp_thirst
ensure lsrp_shops
ensure lsrp_housing
ensure lsrp_loadscreen
ensure lsrp_spawner
ensure lsrp_pededitor
ensure lsrp_vehicleeditor
ensure lsrp_vehiclebehaviour
ensure lsrp_vehicleparking
ensure lsrp_vehicleshop
ensure lsrp_zones
ensure lsrp_mapedits
ensure lsrp_phones

# This allows players to use scripthook-based plugins such as the legacy Lambda Menu.
# Set this to 1 to allow scripthook. Do note that this does _not_ guarantee players won't be able to use external plugins.
sv_scriptHookAllowed 0

# Uncomment this and set a password to enable RCON. Make sure to change the password - it should look like set rcon_password "YOURPASSWORD"
#set rcon_password ""

# A comma-separated list of tags for your server.
sets tags "default"

# A valid locale identifier for your server's primary language.
sets locale "en-US"

# Set an optional server info and connecting banner image url.
#sets banner_detail "https://url.to/image.png"
#sets banner_connecting "https://url.to/image.png"

# Set your server's hostname. This is not usually shown anywhere in listings.
sv_hostname "RP Server"

# Set your server's Project Name
sets sv_projectName "My RP Server Project"

# Set your server's Project Description
sets sv_projectDesc "RP server"

# Set Game Build (https://docs.fivem.net/docs/server-manual/server-commands/#sv_enforcegamebuild-build)
#sv_enforceGameBuild 2802

# Nested local-only config for secrets and machine-specific overrides.
exec server_internal.cfg

# Loading a server icon (96x96 PNG file)
#load_server_icon myLogo.png

# convars which can be used in scripts
set temp_convar "hey world!"

# Remove the `#` from the below line if you want your server to be listed as 'private' in the server browser.
#sv_master1 ""

# Add system admins
add_ace group.admin command allow
add_ace group.admin command.quit deny
add_ace group.admin lsrp.core.connect_when_closed allow
add_ace group.admin lsrp.hunger.test allow
add_ace group.admin lsrp.thirst.test allow
add_ace group.admin lsrp.economy.admin allow

# Optional: allow an in-game bootstrap of the first lsrp_dev admin when the
# persisted dev admin list is empty.
#add_ace group.admin lsrp.dev.manageadmins allow

# enable OneSync (required for server-side state awareness)
set onesync on

# Server player slot limit (see https://fivem.net/server-hosting for limits)
sv_maxclients 48

# Steam Web API key, if you want to use Steam authentication (https://steamcommunity.com/dev/apikey)
set steam_webApiKey ""